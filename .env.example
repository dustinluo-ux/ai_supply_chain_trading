# Multi-Source Alpha Pipeline - Environment Variables
# Copy this file to .env and fill in your API keys

# Tiingo API Key (for news data and ticker tagging)
# Get key from: https://api.tiingo.com/
TIINGO_API_KEY=your_tiingo_api_key_here

# Google/Gemini API Key (for sentiment scoring and supply chain analysis)
# Get key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Marketaux API Key (for live weekly rebalance news)
# Get key from: https://www.marketaux.com/
MARKETAUX_API_KEY=your_marketaux_api_key_here

# EODHD API Key (optional - fallback for price refresh and fundamentals)
# Only needed if yfinance fails for non-US tickers
EODHD_API_KEY=

# IBKR Configuration
IBKR_HOST=127.0.0.1
IBKR_PORT=7497

# Data directory (trading data lives outside repo)
DATA_DIR=C:/ai_supply_chain_trading/trading_data
