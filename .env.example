# Multi-Source Alpha Pipeline - Environment Variables
# Copy this file to .env and fill in your API keys

# Tiingo API Key (for news data and ticker tagging)
# Get key from: https://api.tiingo.com/
TIINGO_API_KEY=your_tiingo_api_key_here

# Google/Gemini API Key (for sentiment scoring and supply chain analysis)
# Get key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Marketaux API Key (for live weekly rebalance news)
# Get key from: https://www.marketaux.com/
MARKETAUX_API_KEY=your_marketaux_api_key_here

# EODHD API Key (news backfill download + non-US ticker price refresh)
# Get key from: https://eodhd.com/
EODHD_API_KEY=

# Financial Modeling Prep API Key (primary fundamentals source: 20-quarter FCFF pipeline)
# Get key from: https://financialmodelingprep.com/developer/docs/
# Free tier: 250 calls/day. Fundamentals require Starter plan ($29/mo) or higher.
FMP_API_KEY=

# SEC EDGAR identity (required by edgartools for 10-K XBRL audit checks)
# Format: "Your Name your@email.com" — SEC policy requires identification
EDGAR_IDENTITY=

# IBKR Configuration
IBKR_HOST=127.0.0.1
IBKR_PORT=7497

# Data directory — REQUIRED, no default fallback
# Trading data lives outside repo to avoid OneDrive sync of large parquet/CSV files.
# Scripts read this via os.environ["DATA_DIR"] — KeyError if unset.
DATA_DIR=C:/ai_supply_chain_trading/trading_data

# Managed Builder (HEAVY kit — run: conda run -n wealth python scripts/managed_builder.py --setup)
MANAGED_BUILDER_ENVIRONMENT_ID=
MANAGED_BUILDER_AGENT_ID=
MANAGED_BUILDER_AGENT_VERSION=
